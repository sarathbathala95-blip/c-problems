#include <stdio.h>

int main() {
    int choice;

    printf("Menu:\n");
    printf("1. Pizza - ₹150\n");
    printf("2. Burger - ₹100\n");
    printf("3. Sandwich - ₹80\n");
    printf("4. Tea - ₹20\n");

    printf("Enter your choice: ");
    scanf("%d", &choice);

    switch(choice) {
        case 1:
            printf("You selected Pizza. Price = ₹150");
            break;
        case 2:
            printf("You selected Burger. Price = ₹100");
            break;
        case 3:
            printf("You selected Sandwich. Price = ₹80");
            break;
        case 4:
            printf("You selected Tea. Price = ₹20");
            break;
        default:
            printf("Invalid choice");
    }

    return 0;
}
