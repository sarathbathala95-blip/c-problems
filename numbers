#include <stdio.h>

int main() {
    int n;

    printf("Enter a number (1-3): ");
    scanf("%d", &n);

    switch(n) {
        case 1:
            printf("One");
            break;
        case 2:
            printf("Two");
            break;
        case 3:
            printf("Three");
            break;
        default:
            printf("Invalid");
    }

    return 0;
}
